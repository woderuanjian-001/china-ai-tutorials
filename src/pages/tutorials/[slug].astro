---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SEO from "../../components/SEO.astro";
import AdUnit from "../../components/AdUnit.astro";

export async function getStaticPaths() {
  const tutorials = await getCollection("tutorials");
  return tutorials.map((t) => ({
    params: { slug: t.slug },
    props: { tutorial: t },
  }));
}

const { tutorial } = Astro.props;
const { Content } = await tutorial.render();
const { title, description, category, date, updated, tags, image, level } = tutorial.data;
const base = import.meta.env.BASE_URL;
---

<BaseLayout currentPath={`/tutorials/${tutorial.slug}/`}>
  <SEO
    slot="head"
    title={title}
    description={description}
    type="article"
    publishedTime={date.toISOString()}
    modifiedTime={updated ? updated.toISOString() : date.toISOString()}
    tags={tags}
    canonicalURL={new URL(`/tutorials/${tutorial.slug}/`, Astro.site).href}
    image={image}
    breadcrumbs={[
      { name: "Home", url: new URL("/", Astro.site).href },
      { name: "Tutorials", url: new URL("/tutorials/", Astro.site).href },
      { name: title, url: new URL(`/tutorials/${tutorial.slug}/`, Astro.site).href },
    ]}
  />

  <article class="tutorial">
    <header class="tutorial-header">
      <div class="tutorial-meta-top">
        <span class="tutorial-category">{category}</span>
        <span class="tutorial-level">{level}</span>
        <time datetime={date.toISOString()}>{date.toLocaleDateString("zh-CN")}</time>
      </div>
      <h1 class="tutorial-title">{title}</h1>
      <p class="tutorial-desc">{description}</p>
      <div class="tutorial-tags">
        {tags.map((tag: string) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    </header>

    <div class="tutorial-body">
      <div class="tutorial-content">
        <Content />
        <!-- 文章内广告位（AdSense 审批通过后自动显示） -->
        <AdUnit slot="article-bottom" format="auto" />
      </div>

      <aside class="tutorial-sidebar">
        <div class="sidebar-sticky">
          <h4 class="sidebar-heading">On this page</h4>
          <nav id="toc" class="toc" aria-label="Table of contents"></nav>
          <div class="sidebar-cta">
            <h4 class="sidebar-heading">Share</h4>
            <button id="share-btn" class="share-btn">Copy link</button>
            <span id="share-msg" class="share-msg"></span>
          </div>
        </div>
      </aside>
    </div>
  </article>

  <!-- 相关教程 -->
  <section class="related-section">
    <div class="container-wide">
      <h2 class="section-title">相关教程</h2>
      <p class="related-placeholder">浏览更多 <a href={`${base}tutorials/`}>教程</a>。</p>
    </div>
  </section>
</BaseLayout>

<style>
  .tutorial {
    padding-top: var(--space-2xl);
  }

  .tutorial-header {
    max-width: 1000px;
    margin: 0 auto var(--space-2xl);
    padding: 0 var(--space-lg);
  }

  .tutorial-meta-top {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
    flex-wrap: wrap;
  }

  .tutorial-category {
    font-weight: 700;
    color: var(--color-accent);
  }

  .tutorial-level {
    padding: 2px 10px;
    background: var(--color-tag-bg);
    border-radius: 50px;
    font-size: var(--text-xs);
    font-weight: 500;
  }

  .tutorial-title {
    font-size: var(--text-3xl);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-md);
    line-height: 1.25;
  }

  .tutorial-desc {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
  }

  .tutorial-tags {
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
  }

  .tag {
    padding: 3px 10px;
    background: var(--color-tag-bg);
    border-radius: 50px;
    font-size: var(--text-xs);
  }

  .tutorial-body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 200px;
    gap: var(--space-2xl);
    align-items: start;
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  .tutorial-content {
    max-width: 100%;
    overflow-x: auto;
    min-width: 0;
  }

  .tutorial-content :global(h2) {
    font-size: var(--text-2xl);
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
  }

  .tutorial-content :global(h3) {
    font-size: var(--text-xl);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
  }

  .tutorial-content :global(p) {
    margin-bottom: var(--space-md);
  }

  .tutorial-content :global(pre) {
    margin-bottom: var(--space-lg);
  }

  .tutorial-content :global(blockquote) {
    border-left-color: var(--color-accent);
  }

  .tutorial-content :global(.callout) {
    padding: var(--space-md) var(--space-lg);
    margin-bottom: var(--space-lg);
    border-radius: var(--radius-md);
    border-left: 4px solid;
    font-size: var(--text-sm);
  }

  .tutorial-content :global(.callout-info) {
    background: #e8f4fd;
    border-color: #2b6cb0;
  }

  .tutorial-content :global(.callout-warning) {
    background: #fef9e7;
    border-color: #d4a017;
  }

  .tutorial-content :global(.callout-tip) {
    background: #eafaf1;
    border-color: #2d8a56;
  }

  .tutorial-sidebar {
    position: relative;
  }

  .sidebar-sticky {
    position: sticky;
    top: 80px;
  }

  .sidebar-heading {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-sm);
  }

  .toc {
    font-size: var(--text-sm);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-lg);
    line-height: 1.6;
  }

  .toc a {
    display: block;
    padding: 3px 0;
    color: var(--color-text-secondary);
    text-decoration: none;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    transition: color var(--duration-fast);
    border-left: 2px solid transparent;
    padding-left: var(--space-sm);
  }

  .toc a:hover {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
    text-decoration: none;
  }

  .sidebar-cta {
    font-size: var(--text-sm);
  }

  .share-btn {
    display: inline-block;
    padding: 6px 14px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all var(--duration-fast);
  }

  .share-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-subtle);
  }

  .share-msg {
    display: block;
    margin-top: 6px;
    font-size: var(--text-xs);
    color: var(--color-green);
  }

  .related-section {
    padding: var(--space-2xl) 0 var(--space-3xl);
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-2xl);
  }

  .section-title {
    margin-top: 0;
  }

  .related-placeholder {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
  }

  @media (max-width: 768px) {
    .tutorial-body {
      grid-template-columns: 1fr;
    }
    .tutorial-sidebar {
      display: none;
    }
    .tutorial-title {
      font-size: var(--text-2xl);
    }
  }
</style>

<script>
  // === 动态生成目录 (TOC) ===
  function buildTOC() {
    const toc = document.getElementById("toc");
    const content = document.querySelector(".tutorial-content");
    if (!toc || !content) return;

    const headings = content.querySelectorAll("h2");
    if (headings.length === 0) {
      toc.innerHTML = '<span style="color:var(--color-text-muted);font-size:var(--text-xs)">No headings</span>';
      return;
    }

    const list = document.createElement("div");
    headings.forEach((h2, i) => {
      // 给 h2 添加 id 以便锚点跳转
      const id = h2.id || `heading-${i}`;
      if (!h2.id) h2.id = id;

      const a = document.createElement("a");
      a.href = `#${id}`;
      a.textContent = h2.textContent || "";
      list.appendChild(a);
    });
    toc.appendChild(list);
  }

  // === 分享按钮 ===
  function setupShare() {
    const btn = document.getElementById("share-btn");
    const msg = document.getElementById("share-msg");
    if (!btn || !msg) return;

    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        msg.textContent = "✓ Link copied!";
        msg.style.color = "var(--color-green)";
      } catch {
        msg.textContent = "Failed to copy";
        msg.style.color = "var(--color-magenta)";
      }
      setTimeout(() => { msg.textContent = ""; }, 2000);
    });
  }

  buildTOC();
  setupShare();
</script>
