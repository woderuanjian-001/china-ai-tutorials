---
import BaseLayout from "../layouts/BaseLayout.astro";
import SEO from "../components/SEO.astro";
import SearchBox from "../components/SearchBox.astro";
import { getCollection } from "astro:content";

// 从 Content Collection 动态加载最新教程
const allTutorials = await getCollection("tutorials");
allTutorials.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredTutorials = allTutorials.slice(0, 6);

// 分类统计
const categoryCounts = new Map<string, number>();
for (const t of allTutorials) {
  const cat = t.data.category;
  categoryCounts.set(cat, (categoryCounts.get(cat) || 0) + 1);
}

// 分类数据
const categories = [
  {
    slug: "deepseek",
    title: "DeepSeek",
    emoji: "🐋",
    description: "The world's strongest open-source coding model. V4 API hands-on tutorials for developers.",
    count: categoryCounts.get("DeepSeek") || 0,
  },
  {
    slug: "kimi",
    title: "Kimi (Moonshot AI)",
    emoji: "🌙",
    description: "Moonshot AI — 256K ultra-long context, the king of large document analysis.",
    count: categoryCounts.get("Kimi") || 0,
  },
  {
    slug: "qwen",
    title: "Qwen (Alibaba)",
    emoji: "☁️",
    description: "Alibaba Cloud — the most complete open-source AI ecosystem with enterprise-grade multimodal models.",
    count: categoryCounts.get("Qwen") || 0,
  },
  {
    slug: "doubao",
    title: "Doubao (ByteDance)",
    emoji: "🫘",
    description: "ByteDance — 157 million users and counting, the most accessible AI for everyday tasks.",
    count: categoryCounts.get("Doubao") || 0,
  },
  {
    slug: "zhipuai",
    title: "ZhipuAI (GLM)",
    emoji: "🧠",
    description: "Tsinghua-backed — language, vision, video, and real-time AI in one complete multimodal product line.",
    count: categoryCounts.get("ZhipuAI") || 0,
  },
  {
    slug: "xiaomi",
    title: "Xiaomi (MiMo)",
    emoji: "📱",
    description: "1M token context + #1 open-source on SWE-Bench. The ultimate coding agent foundation model.",
    count: categoryCounts.get("Xiaomi") || 0,
  },
  {
    slug: "kuaishou",
    title: "Kuaishou (Kling)",
    emoji: "🎬",
    description: "China's most powerful video generation API — text-to-video, image-to-video, and multi-shot filmmaking.",
    count: categoryCounts.get("Kuaishou") || 0,
  },
  {
    slug: "comparison",
    title: "Comparisons & Benchmarks",
    emoji: "⚖️",
    description: "Side-by-side comparisons of Chinese AI models to help you pick the right tool for every task.",
    count: categoryCounts.get("Comparisons") || 0,
  },
];

// 平台数量（不含对比分类）
const platformCount = categories.filter((c) => c.count > 0 && c.slug !== "comparison").length;

const base = import.meta.env.BASE_URL;

// 日期格式化
function formatDate(d: Date): string {
  return d.toISOString().split("T")[0];
}
---

<BaseLayout currentPath="/">
  <SEO
    slot="head"
    title="Learn Chinese AI Models — Hands-On Tutorials for Global Developers"
    description="China AI Tutorials — The most comprehensive English-language guide to Chinese AI tools. DeepSeek, Kimi, Qwen, Doubao, ZhipuAI, Xiaomi, Kuaishou API tutorials with runnable code. Zero to production."
    type="website"
  />

  <!-- Hero 区域 -->
  <section class="hero">
    <div class="hero-content">
      <p class="hero-kicker">China AI Tutorials</p>
      <h1 class="hero-title">
        Master China's Most Powerful AI Tools
      </h1>
      <p class="hero-desc">
        DeepSeek, Kimi, Qwen, Doubao, ZhipuAI, MiMo, Kling — Chinese AI models are reshaping the world.
        Code-driven tutorials that take you from zero to production with runnable examples every step of the way.
      </p>
      <div class="hero-search">
        <SearchBox />
      </div>
      <div class="hero-actions">
        <a href={`${base}tutorials/`} class="btn-primary">Browse all tutorials</a>
        <a href={`${base}tutorials/china-ai-model-comparison-2026/`} class="btn-secondary">Model comparison →</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-number">{allTutorials.length}+</span>
          <span class="stat-label">In-depth tutorials</span>
        </div>
        <div class="stat">
          <span class="stat-number">{platformCount}</span>
          <span class="stat-label">AI platforms</span>
        </div>
        <div class="stat">
          <span class="stat-number">100%</span>
          <span class="stat-label">Free & open source</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 分类导航 -->
  <section class="section">
    <div class="container-wide">
      <h2 class="section-title">Learn by platform</h2>
      <div class="category-grid">
        {categories.map((cat) => (
          <a href={`${base}tutorials/?category=${cat.slug}`} class="category-card">
            <span class="cat-emoji">{cat.emoji}</span>
            <div class="cat-body">
              <h3 class="cat-title">{cat.title}</h3>
              <p class="cat-desc">{cat.description}</p>
              <span class="cat-count">{cat.count} tutorials</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 最新教程 -->
  <section class="section">
    <div class="container-wide">
      <div class="section-header">
        <h2 class="section-title">Latest tutorials</h2>
        <a href={`${base}tutorials/`} class="section-link">View all ({allTutorials.length}) →</a>
      </div>
      <div class="article-grid">
        {featuredTutorials.map((tutorial) => (
          <article class="article-card">
            <a href={`${base}tutorials/${tutorial.slug}/`} class="article-link">
              <div class="article-category">{tutorial.data.category}</div>
              <h3 class="article-title">{tutorial.data.title}</h3>
              <p class="article-desc">{tutorial.data.description}</p>
              <div class="article-meta">
                <time datetime={formatDate(tutorial.data.date)}>{formatDate(tutorial.data.date)}</time>
                <div class="article-tags">
                  {tutorial.data.tags.slice(0, 3).map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 为什么选择我们 -->
  <section class="section section-alt">
    <div class="container-wide">
      <h2 class="section-title">Why China AI Tutorials?</h2>
      <div class="features-grid">
        <div class="feature-card">
          <span class="feature-icon">🔄</span>
          <h3>Latest API, actually tested</h3>
          <p>Every code snippet is verified against the latest API. Dated "as of Month 2026" — no outdated tutorials here.</p>
        </div>
        <div class="feature-card">
          <span class="feature-icon">🌏</span>
          <h3>Chinese sources → English output</h3>
          <p>We dig deep into Chinese official docs and community knowledge, then present it in fluent English. We bridge the language gap so you don't have to.</p>
        </div>
        <div class="feature-card">
          <span class="feature-icon">💻</span>
          <h3>Code-driven, not theory</h3>
          <p>No armchair commentary. Every tutorial includes runnable code examples — copy, paste, and it works.</p>
        </div>
        <div class="feature-card">
          <span class="feature-icon">🎯</span>
          <h3>Zero to production</h3>
          <p>From signing up for an API key to deploying a working app. Every step broken down. Basic Python knowledge is all you need.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============================================
     Homepage — Warm Minimal (Claude/anthropic.com inspired)
     ============================================ */

  /* === Hero === */
  .hero {
    padding: var(--space-3xl) 0 var(--space-2xl);
    text-align: center;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
    max-width: 720px;
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  .hero-kicker {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
    max-width: 660px;
    margin: 0;
    color: var(--color-text);
  }

  .hero-desc {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 560px;
    margin: 0;
    line-height: 1.7;
  }

  .hero-search {
    width: 100%;
    max-width: 500px;
    margin-top: var(--space-sm);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    justify-content: center;
    margin-top: var(--space-sm);
  }

  /* 按钮 */
  .btn-primary,
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 10px 24px;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--text-sm);
    border-radius: var(--radius-sm);
    transition: all var(--duration-normal) var(--ease-out-expo);
    text-decoration: none;
    cursor: pointer;
  }

  .btn-primary {
    background: var(--color-accent);
    color: #FFFFFF;
    border: none;
    box-shadow: var(--shadow-button);
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    color: #FFFFFF;
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(217, 119, 6, 0.2);
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border-strong);
  }

  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    text-decoration: none;
    background: var(--color-accent-subtle);
  }

  /* 统计数字 */
  .hero-stats {
    display: flex;
    gap: var(--space-2xl);
    margin-top: var(--space-xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
  }

  /* === Section 通用 === */
  .section {
    padding: var(--space-2xl) 0;
  }

  .section-alt {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-xl);
  }

  .section-title {
    margin-top: 0;
    margin-bottom: var(--space-xl);
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .section-link {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
  }

  .section-link:hover {
    color: var(--color-accent-hover);
  }

  /* === 分类卡片 === */
  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-md);
  }

  .category-card {
    display: flex;
    gap: var(--space-md);
    padding: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: all var(--duration-normal) var(--ease-out-expo);
    text-decoration: none;
    color: var(--color-text);
  }

  .category-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-card-hover);
    text-decoration: none;
    transform: translateY(-2px);
  }

  .cat-emoji {
    font-size: 1.75rem;
    flex-shrink: 0;
  }

  .cat-body { flex: 1; min-width: 0; }

  .cat-title {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 var(--space-xs);
    color: var(--color-text);
    line-height: 1.3;
  }

  .cat-desc {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-sm);
    line-height: 1.6;
  }

  .cat-count {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent);
  }

  /* === 文章卡片 === */
  .article-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-md);
  }

  .article-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: all var(--duration-normal) var(--ease-out-expo);
  }

  .article-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }

  .article-link {
    display: block;
    padding: var(--space-lg);
    text-decoration: none;
    color: inherit;
  }

  .article-link:hover {
    text-decoration: none;
    color: inherit;
  }

  .article-category {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .article-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 var(--space-sm);
    line-height: 1.35;
    color: var(--color-text);
  }

  .article-desc {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-md);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .article-tags {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }

  .tag {
    padding: 2px 8px;
    background: var(--color-tag-bg);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-tag-text);
    font-weight: 500;
  }

  /* === 特色卡片 === */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    gap: var(--space-xl);
  }

  .feature-card {
    text-align: left;
    padding: var(--space-xl);
    background: var(--color-bg);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    transition: all var(--duration-normal) var(--ease-out-expo);
  }

  .feature-card:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-card-hover);
  }

  .feature-icon {
    font-size: 1.75rem;
    display: block;
    margin-bottom: var(--space-md);
  }

  .feature-card h3 {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 var(--space-sm);
    color: var(--color-text);
  }

  .feature-card p {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.65;
  }

  /* === 响应式 === */
  @media (max-width: 640px) {
    .hero-stats { gap: var(--space-lg); }
    .article-grid,
    .category-grid { grid-template-columns: 1fr; }
    .hero-title { font-size: var(--text-3xl); }
    .hero-desc { font-size: var(--text-base); }
  }
</style>
