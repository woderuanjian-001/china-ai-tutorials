---
// ============================================================================
// AffiliateButton.astro — 联盟营销按钮（统一管理 + FTC 合规）
// ============================================================================
//
// 用法（在 .md 教程里直接调用）：
//   <AffiliateButton platform="deepseek" />
//   <AffiliateButton platform="deepseek" text="自定义按钮文字 →" />
//   <AffiliateButton platform="qwen" size="lg" />
//
// 用法（在 .astro 页面里）：
//   import AffiliateButton from "../components/AffiliateButton.astro";
//   <AffiliateButton platform="deepseek" />
//
// 合规设计：
// 1. 所有联盟链接自动加 rel="sponsored noopener noreferrer"（Google + FTC 要求）
// 2. 按钮下方自动显示 FTC 披露文案（disclosure 字段）
// 3. monetized: false 的平台渲染为普通链接（无 sponsored rel，无披露）
// 4. 按钮样式与 AdSense 区分（避免被误判为广告位）
//
// ============================================================================

import { AFFILIATE_LINKS, type AffiliatePlatform } from "../config";

export interface Props {
  /** 平台键名（必须对应 AFFILIATE_LINKS 里的 key） */
  platform: AffiliatePlatform;
  /** 自定义按钮文字，不传则用默认文案 */
  text?: string;
  /** 按钮尺寸 */
  size?: "sm" | "md" | "lg";
  /** 是否显示 FTC 披露（默认显示，列表页可关闭） */
  showDisclosure?: boolean;
  /** 额外的 CSS class */
  class?: string;
}

const {
  platform,
  text,
  size = "md",
  showDisclosure = true,
  class: className = "",
} = Astro.props;

// 类型安全：platform 必须是 AFFILIATE_LINKS 的合法 key
const link = AFFILIATE_LINKS[platform];
if (!link) {
  throw new Error(
    `AffiliateButton: platform "${platform}" 不存在。可用：${Object.keys(AFFILIATE_LINKS).join(", ")}`
  );
}

// 按钮文字：优先用调用方传入的，否则用默认模板
const buttonText = text || `Get started with ${link.label}`;

// 联盟链接的 rel 属性：monetized 时加 sponsored（Google 和 FTC 要求）
// 非 monetized 时是普通外链，用 noopener noreferrer 即可
const relAttr = link.monetized
  ? "sponsored noopener noreferrer"
  : "noopener noreferrer";
---

<div class={`affiliate-block affiliate-${size} ${className}`}>
  <a
    href={link.url}
    target="_blank"
    rel={relAttr}
    class="affiliate-btn"
    data-platform={platform}
    aria-label={`${buttonText} (opens in new tab)`}
  >
    <span class="affiliate-btn-text">{buttonText}</span>
    <span class="affiliate-btn-arrow" aria-hidden="true">→</span>
  </a>

  {showDisclosure && link.disclosure && (
    <p class="affiliate-disclosure">
      <span class="affiliate-disclosure-icon" aria-hidden="true">⚠️</span>
      <span class="affiliate-disclosure-text">Affiliate link: {link.disclosure}</span>
    </p>
  )}
</div>

<style>
  .affiliate-block {
    margin: 1.5rem 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.4rem;
  }

  .affiliate-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: #d97706;
    color: #ffffff !important;
    border: 2px solid #d97706;
    border-radius: 8px;
    font-family: var(--font-body, "Inter", system-ui, sans-serif);
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    line-height: 1.2;
    transition: all 0.15s ease;
    cursor: pointer;
  }

  .affiliate-btn:hover {
    background: #b45309;
    border-color: #b45309;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(217, 119, 6, 0.3);
  }

  .affiliate-btn:active {
    transform: translateY(0);
  }

  .affiliate-btn:focus-visible {
    outline: 2px solid #d97706;
    outline-offset: 3px;
  }

  .affiliate-btn-arrow {
    transition: transform 0.15s ease;
    font-weight: 700;
  }

  .affiliate-btn:hover .affiliate-btn-arrow {
    transform: translateX(3px);
  }

  /* 尺寸变体 */
  .affiliate-sm .affiliate-btn {
    padding: 0.5rem 1rem;
    font-size: 0.8125rem;
  }

  .affiliate-lg .affiliate-btn {
    padding: 1rem 2rem;
    font-size: 1.0625rem;
  }

  /* FTC 披露文案 */
  .affiliate-disclosure {
    display: flex;
    align-items: flex-start;
    gap: 0.35rem;
    margin: 0;
    font-size: 0.75rem;
    line-height: 1.5;
    color: #6b7280;
    font-style: italic;
    max-width: 600px;
  }

  .affiliate-disclosure-icon {
    flex-shrink: 0;
    line-height: 1.5;
  }

  /* 响应式 */
  @media (max-width: 640px) {
    .affiliate-btn {
      width: 100%;
      justify-content: center;
    }
  }

  /* 尊重用户减少动画偏好 */
  @media (prefers-reduced-motion: reduce) {
    .affiliate-btn,
    .affiliate-btn-arrow,
    .affiliate-btn:hover {
      transition: none;
      transform: none;
      box-shadow: none;
    }
  }
</style>
