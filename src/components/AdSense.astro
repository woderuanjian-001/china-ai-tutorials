---
// ============================================================================
// AdSense.astro — Google AdSense 广告组件（Consent Mode v2 升级版）
// ============================================================================
//
// 相比原版的改进：
// 1. ✅ 在 <head> 顶部预设 Google Consent Mode v2 默认 deny
//    这是 2024 年 3 月后欧洲经济区 AdSense 合规的强制要求
// 2. ✅ 用户拒绝广告后，adsbygoogle 脚本不再加载（不只是禁用个性化）
// 3. ✅ 监听 cookie_consent_change 事件，用户事后改主意也能动态加载
// 4. ✅ 保留原有的「广告被屏蔽时隐藏广告位」容错
// 5. ✅ 把 AdSense 验证（Search Console 关联）相关的 meta 标签统一管理
//
// 部署清单：
// - 把本组件放在 BaseLayout 的 <head> 里（已就位）
// - 必须在所有其他带 gtag 的脚本之前（Consent Mode 默认值要最早执行）
// ============================================================================

import { SITE_CONFIG } from "../config";
const { enabled, publisherId } = SITE_CONFIG.adsense;
---

{enabled && (
  <>
    {/* =====================================================================
        1. Google Consent Mode v2 默认值（必须最早执行，先于 gtag.js 加载）
        =====================================================================
        即使 AdSense 审核没过，这段也要保留——它是合规基础设施。
        默认全部 denied，用户同意后由 CookieConsent 组件 push update。
        ===================================================================== */}
    <script is:inline define:vars={{ publisherId }}>
      // Consent Mode v2 默认值（必须用 set:inline 保证不被 Astro 编译/延迟）
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag("consent", "default", {
        ad_storage: "denied",
        ad_user_data: "denied",
        ad_personalization: "denied",
        analytics_storage: "denied",
        wait_for_update: 500,
      });

      // 从 localStorage 读取已保存的同意状态，提前同步（避免首屏广告错乱）
      try {
        const raw = localStorage.getItem("cookie_consent_v2");
        if (raw) {
          const c = JSON.parse(raw);
          gtag("consent", "update", {
            ad_storage: c.advertising ? "granted" : "denied",
            ad_user_data: c.advertising ? "granted" : "denied",
            ad_personalization: c.advertising ? "granted" : "denied",
            analytics_storage: c.analytics ? "granted" : "denied",
          });
          // 标记：已有同意记录
          window.__consentResolved = true;
        }
      } catch (e) {}

      // ===================================================================
      // 2. 根据同意状态加载 AdSense 脚本
      // ===================================================================
      // 关键：用户拒绝广告时，根本不加载 adsbygoogle.js
      // （只靠 Consent Mode 不够——脚本本身也带了 Cookie，最稳是「不加载」）
      window.__loadAdSense = function () {
        if (window.__adsenseLoaded) return;
        window.__adsenseLoaded = true;

        const s = document.createElement("script");
        s.async = true;
        s.src =
          "https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-" +
          publisherId;
        s.crossOrigin = "anonymous";

        // 加载失败时（被广告拦截器阻止）隐藏所有广告位
        s.onerror = function () {
          document.querySelectorAll(".ad-container").forEach(function (el) {
            (el).style.display = "none";
          });
        };
        document.head.appendChild(s);
      };

      // 检查同意状态，决定是否立即加载
      function checkAndLoadAds() {
        try {
          const raw = localStorage.getItem("cookie_consent_v2");
          if (raw) {
            const c = JSON.parse(raw);
            if (c.advertising) {
              window.__loadAdSense();
            }
          }
          // 没有同意记录时不加载，等 CookieConsent 组件触发
        } catch (e) {}
      }

      // 用户事后改主意：监听 consent 变化事件
      window.addEventListener("cookie_consent_change", function (e) {
        if (e.detail && e.detail.advertising) {
          window.__loadAdSense();
        }
      });

      // 首次检查（已有同意记录则立即加载）
      checkAndLoadAds();
    </script>

    {/* =====================================================================
        3. 广告位空容器自动隐藏（防广告拦截器留空白）
        ===================================================================== */}
    <style>{`.ad-container:empty{display:none!important}`}</style>
  </>
)}

{/* ============================================================================
    4. AdSense + Search Console 关联验证（如果你用 AdSense 验证站点所有权）
    ========================================================================== */}
{/* 如需用 AdSense 验证 Search Console，取消注释并填入你的验证码：
<meta name="google-adsense-account" content="ca-pub-1325551504808613" />
*/}
