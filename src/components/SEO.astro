---
// SEO 组件 — 统一管理页面 meta 标签 + 结构化数据
// 修复历史问题：所有 URL（og:url、canonical、JSON-LD、image）统一用绝对路径
import { SITE_CONFIG, absoluteUrl, absoluteImageUrl } from "../config";

export interface Props {
  title: string;
  description: string;
  image?: string;
  /** 当前页面的相对路径（如 "/tutorials/foo/"），用于生成 canonical 和 og:url */
  canonicalPath?: string;
  /** 兼容旧字段名 canonicalURL，不推荐使用 */
  canonicalURL?: string;
  type?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
  /** 面包屑导航，用于生成 BreadcrumbList 结构化数据 */
  breadcrumbs?: { name: string; path: string }[];
}

const {
  title,
  description,
  image,
  canonicalPath,
  canonicalURL,
  type = "website",
  publishedTime,
  modifiedTime,
  tags = [],
  breadcrumbs,
} = Astro.props;

const fullTitle = type === "article"
  ? `${title} — China AI Tutorials`
  : `${title} — China AI Tutorials`;

// ============================================================================
// 计算 canonical / og:url 的绝对 URL
// ============================================================================
// 优先级：canonicalPath（推荐，传相对路径）> canonicalURL（兼容旧代码）
// 输入归一化：去掉可能混入的 base 前缀，避免重复
let resolvedPath = canonicalPath || canonicalURL || "/";

// 兼容历史代码：如果传入的是绝对 URL，提取其中的 path
if (resolvedPath.startsWith("http")) {
  try {
    resolvedPath = new URL(resolvedPath).pathname;
  } catch {
    resolvedPath = "/";
  }
}

// 去掉可能混入的 base 前缀（避免出现 /china-ai-tutorials/china-ai-tutorials/...）
const base = SITE_CONFIG.base;
if (resolvedPath.startsWith(base)) {
  resolvedPath = resolvedPath.slice(base.length - 1); // 保留前导 /
}
if (!resolvedPath.startsWith("/")) {
  resolvedPath = "/" + resolvedPath;
}

const canonicalAbsUrl = absoluteUrl(resolvedPath);
const ogImageAbsUrl = absoluteImageUrl(image);
---

<!-- 基础 Meta -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalAbsUrl} />

<!-- Open Graph（全部使用绝对 URL，社交分享才能正确显示预览图） -->
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalAbsUrl} />
<meta property="og:image" content={ogImageAbsUrl} />
<meta property="og:image:alt" content={title} />
<meta property="og:site_name" content="China AI Tutorials" />
<meta property="og:locale" content="en_US" />

<!-- Twitter Card（全部使用绝对 URL） -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageAbsUrl} />
<meta name="twitter:image:alt" content={title} />

<!-- 文章专用标签 -->
{type === "article" && publishedTime && (
  <meta property="article:published_time" content={publishedTime} />
)}
{type === "article" && modifiedTime && (
  <meta property="article:modified_time" content={modifiedTime} />
)}
{tags.map((tag) => (
  <meta property="article:tag" content={tag} />
))}

<!-- JSON-LD 结构化数据 — 文章类型（image 改为绝对 URL） -->
{type === "article" && (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    headline: title,
    description: description,
    image: ogImageAbsUrl,
    datePublished: publishedTime,
    dateModified: modifiedTime || publishedTime,
    author: {
      "@type": "Person",
      name: "China AI Tutorials Team",
    },
    publisher: {
      "@type": "Organization",
      name: "China AI Tutorials",
      logo: {
        "@type": "ImageObject",
        url: absoluteUrl("/images/logo.png"),
      },
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": canonicalAbsUrl,
    },
  })} />
)}

<!-- JSON-LD 结构化数据 — 网站类型（修复 url 字段：之前指向根路径，缺少 base 前缀） -->
{type === "website" && (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "China AI Tutorials",
    description: "Hands-on tutorials helping developers worldwide master Chinese AI tools — DeepSeek, Qwen, Kimi, GLM, and more.",
    url: absoluteUrl("/"),
    potentialAction: {
      "@type": "SearchAction",
      target: {
        "@type": "EntryPoint",
        urlTemplate: absoluteUrl("/tutorials/?search={search_term_string}"),
      },
      "query-input": "required name=search_term_string",
    },
  })} />
)}

<!-- JSON-LD 结构化数据 — 面包屑（path 自动转绝对 URL） -->
{breadcrumbs && breadcrumbs.length > 0 && (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: breadcrumbs.map((crumb, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: crumb.name,
      item: absoluteUrl(crumb.path),
    })),
  })} />
)}
