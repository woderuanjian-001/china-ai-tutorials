---
// SEO 组件 — 统一管理页面 meta 标签
export interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
  type?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
}

const {
  title,
  description,
  image = "/images/og-default.png",
  canonicalURL,
  type = "website",
  publishedTime,
  modifiedTime,
  tags = [],
} = Astro.props;

const fullTitle = type === "article"
  ? `${title} — China AI Tutorials`
  : `${title} — China AI Tutorials`;
---

<!-- 基础 Meta -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL || Astro.url.href} />

<!-- Open Graph -->
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL || Astro.url.href} />
<meta property="og:image" content={image} />
<meta property="og:site_name" content="China AI Tutorials" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={image} />

<!-- 文章专用标签 -->
{type === "article" && publishedTime && (
  <meta property="article:published_time" content={publishedTime} />
)}
{type === "article" && modifiedTime && (
  <meta property="article:modified_time" content={modifiedTime} />
)}
{tags.map((tag) => (
  <meta property="article:tag" content={tag} />
))}

<!-- JSON-LD 结构化数据 -->
{type === "article" ? (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    headline: title,
    description: description,
    image: image,
    datePublished: publishedTime,
    dateModified: modifiedTime || publishedTime,
    author: {
      "@type": "Person",
      name: "China AI Tutorials Team",
    },
    publisher: {
      "@type": "Organization",
      name: "China AI Tutorials",
    },
  })} />
) : (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "China AI Tutorials",
    description: "Hands-on tutorials helping developers worldwide master Chinese AI tools — DeepSeek, Qwen, Kimi, GLM, and more.",
    url: Astro.site?.href || "https://china-ai-tutorials.com",
  })} />
)}
